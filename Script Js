function renderTripDateFilter() {
  const select = document.getElementById('adminTripDateFilter');
  const uniqueDates = [...new Set(appData.reservations.map(reservation => reservation.tripDate))].sort();

  if (uniqueDates.length === 0) {
    select.innerHTML = '<option value="">Geen datums beschikbaar</option>';
    renderTripReservations();
    return;
  }

  const currentValue = select.value;
  select.innerHTML = '';

  uniqueDates.forEach(date => {
    select.innerHTML += `<option value="${date}">${date}</option>`;
  });

  if (uniqueDates.includes(currentValue)) {
    select.value = currentValue;
  }

  renderTripReservations();
}

function renderTripReservations() {
  const container = document.getElementById('tripReservationsTable');
  const selectedDate = document.getElementById('adminTripDateFilter').value;

  if (!selectedDate) {
    container.innerHTML = '<p class="small-text">Nog geen verplaatsingen beschikbaar.</p>';
    return;
  }

  const reservations = appData.reservations.filter(reservation => reservation.tripDate === selectedDate);

  if (reservations.length === 0) {
    container.innerHTML = '<p class="small-text">Geen inschrijvingen voor deze datum.</p>';
    return;
  }

  let html = `
    <table>
      <thead>
        <tr>
          <th>Hoofdgebruiker</th>
          <th>Ingeschreven personen</th>
          <th>Betaalstatus</th>
          <th>Actie</th>
        </tr>
      </thead>
      <tbody>
  `;

  reservations.forEach(reservation => {
    html += `
      <tr>
        <td>${reservation.ownerName}</td>
        <td>${reservation.persons.join('<br>')}</td>
        <td>${reservation.paymentStatus}</td>
        <td><button class="btn btn-danger" onclick="deleteReservation('${reservation.id}')">Verwijderen</button></td>
      </tr>
    `;
  });

  html += '</tbody></table>';
  container.innerHTML = html;
}

function simulatePaymentRequest() {
  const output = document.getElementById('paymentDemoResult');
  output.textContent = 'Demo: hier kan later een echte Bancontact-betaallink of QR-koppeling komen via een betaalprovider zoals Mollie of Stripe.';
}

function renderAll() {
  renderOwnerSelects();
  renderMemberOverview();
  renderAdminManagement();
  renderAdminMemberList();
  renderTripDateFilter();
}

document.getElementById('mainMemberForm').addEventListener('submit', addMainMember);
document.getElementById('familyForm').addEventListener('submit', addFamilyMember);
document.getElementById('reservationForm').addEventListener('submit', addReservation);
document.getElementById('reservationOwner').addEventListener('change', updatePersonChecklist);

loadData();
